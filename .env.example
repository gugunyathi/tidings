# Copy this file to .env and fill in your values — never commit .env

VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your_project.supabase.co

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# MongoDB
VITE_MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/

# Base Pay — USDC recipient address on Base Mainnet
VITE_PAYMENT_ADDRESS=0xYOUR_WALLET_ADDRESS
